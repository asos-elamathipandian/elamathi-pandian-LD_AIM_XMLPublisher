<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="src/web-server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="src/web-server.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode node_env="production"
             watchedFiles="web.config"
             loggingEnabled="true"
             logDirectory="iisnode" />
  </system.webServer>
</configuration>
