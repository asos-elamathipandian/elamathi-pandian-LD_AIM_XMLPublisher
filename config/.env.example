SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=your-username
SFTP_PASSWORD=<your-password>
SFTP_PASSPHRASE=<optional-private-key-passphrase>
SFTP_PRIVATE_KEY_PATH=<optional-path-to-private-key>
SFTP_REMOTE_DIR=/remote/upload/path
OUTPUT_DIR=output
STATE_DIR=state
ABV_COUNTER_FILE=
CARRIER_SEQUENCE_FILE=
AZURE_BLOB_CONNECTION_STRING=<your-azure-blob-connection-string>
AZURE_BLOB_CONTAINER=sftp-inbound
